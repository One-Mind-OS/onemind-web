# OneMind Web (SwarmClaw UI) — Environment Variables
# Copy to .env.local and fill in values.

# --- Required ---
NODE_ENV=production
PORT=3456
HOSTNAME=0.0.0.0

# --- OpenClaw Gateway Connection ---
# The gateway URL for the backend to connect to OpenClaw
OPENCLAW_GATEWAY_URL=http://localhost:18789
OPENCLAW_GATEWAY_TOKEN=                  # Must match the gateway's auth token

# --- Optional ---
# NEXT_ALLOWED_DEV_ORIGINS=localhost,127.0.0.1   # Additional allowed origins for dev mode
# SWARMCLAW_BUILD_MODE=1                          # Set during Docker builds to limit CPU (avoids SQLITE_BUSY)
# NEXT_PUBLIC_GIT_SHA=                             # Auto-set during build for version display
